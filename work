#!/bin/bash
# ai workspace - 작업 관리 스크립트

set -e

GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
DIM='\033[2m'
NC='\033[0m'

DATE=$(date +%Y-%m-%d)
YEAR=$(date +%Y)
MONTH=$(date +%m)
LOG_DIR="history/$YEAR/$MONTH"

# ============================================================
show_help() {
    echo -e "${BLUE}ai workspace${NC}\n"
    echo "  ${GREEN}./work start${NC}  \"작업명\"         작업 시작 (history/ 로그 생성)"
    echo "  ${GREEN}./work save${NC}   \"메시지\"         중간 저장 (상태 갱신, commit 없음)"
    echo "  ${GREEN}./work done${NC}   \"메시지\"         작업 완료 (상태 갱신 + git commit/push)"
    echo "  ${GREEN}./work status${NC}                  현재 상태"
    echo "  ${GREEN}./work jira list${NC}               Jira 태스크 목록"
    echo "  ${GREEN}./work jira new${NC}  \"태스크명\"    새 태스크 생성"
    echo "  ${GREEN}./work jira done${NC} \"파일명\"      태스크 완료 처리"
    echo ""
}

# ============================================================
work_start() {
    local TITLE="${1:-work}"
    local SLUG=$(echo "$TITLE" | tr ' ' '-' | tr '[:upper:]' '[:lower:]')
    local LOG_FILE="$LOG_DIR/$DATE-$SLUG.md"

    mkdir -p "$LOG_DIR"

    if [ -f "$LOG_FILE" ]; then
        echo -e "${YELLOW}이미 존재: $LOG_FILE${NC}"
        return 0
    fi

    local GIT_USER=$(git config user.name 2>/dev/null || echo "[이름]")

    cat > "$LOG_FILE" << EOF
---
date: $DATE
title: $TITLE
tags: []
---

# $DATE $TITLE
> (작업 완료 후 한 줄 요약 작성)

## 목표
> $TITLE

## 작업 내용
-

## 성과 포인트
-

## 변경 사항
-

## 이슈
-

## 다음 작업
-

---
**작성자**: $GIT_USER
EOF

    echo -e "${GREEN}✅ $LOG_FILE${NC}"
}

# ============================================================
update_status() {
    local MSG="$1"
    mkdir -p context

    local RECENT_LOG=$(find history -name "*.md" -not -name "index.md" -type f 2>/dev/null | sort -r | head -1)
    local NEXT_TASKS=""
    if [ -n "$RECENT_LOG" ] && [ -f "$RECENT_LOG" ]; then
        NEXT_TASKS=$(sed -n '/## 다음 작업/,/^---/p' "$RECENT_LOG" 2>/dev/null | grep "^- " | head -5)
    fi

    cat > context/current_status.md << EOF
# 현재 진행 상황

## 마지막 완료
- $MSG ($(date '+%Y-%m-%d %H:%M'))

## 다음 작업
${NEXT_TASKS:-"- (미정)"}

## 최근 작업
EOF

    find history -name "*.md" -not -name "index.md" -type f 2>/dev/null | sort -r | head -7 | while read file; do
        echo "- $(basename "$file" .md)" >> context/current_status.md
    done
}

# ============================================================
update_index() {
    cat > history/index.md << 'EOF'
# 작업 이력

| 날짜 | 작업 | 파일 |
|------|------|------|
EOF

    find history -name "*.md" -not -name "index.md" -type f 2>/dev/null | sort -r | while read file; do
        local fname=$(basename "$file" .md)
        local fdate=$(echo "$fname" | grep -oE '^[0-9]{4}-[0-9]{2}-[0-9]{2}' || echo "")
        local ftitle=$(echo "$fname" | sed 's/^[0-9]\{4\}-[0-9]\{2\}-[0-9]\{2\}-//' | tr '-' ' ')
        echo "| ${fdate:-?} | ${ftitle:-$fname} | [$fname]($file) |" >> history/index.md
    done
}

# ============================================================
update_jira_index() {
    mkdir -p jira/open jira/done

    cat > jira/index.md << 'EOF'
# Jira 태스크 목록

## 진행 중 (open)

| 날짜 | 제목 | 유형 | 우선순위 |
|------|------|------|---------|
EOF

    find jira/open -name "*.md" -type f 2>/dev/null | sort -r | while read file; do
        local fname=$(basename "$file" .md)
        local title=$(grep "^title:" "$file" 2>/dev/null | sed 's/^title: //' || echo "$fname")
        local type=$(grep "^type:" "$file" 2>/dev/null | sed 's/^type: //' || echo "-")
        local priority=$(grep "^priority:" "$file" 2>/dev/null | sed 's/^priority: //' || echo "-")
        local fdate=$(echo "$fname" | grep -oE '^[0-9]{4}-[0-9]{2}-[0-9]{2}' || echo "")
        echo "| ${fdate:-?} | [$title]($file) | $type | $priority |" >> jira/index.md
    done

    printf '\n## 완료 (done)\n\n| 날짜 | 제목 | 유형 |\n|------|------|------|\n' >> jira/index.md

    find jira/done -name "*.md" -type f 2>/dev/null | sort -r | head -10 | while read file; do
        local fname=$(basename "$file" .md)
        local title=$(grep "^title:" "$file" 2>/dev/null | sed 's/^title: //' || echo "$fname")
        local type=$(grep "^type:" "$file" 2>/dev/null | sed 's/^type: //' || echo "-")
        local fdate=$(echo "$fname" | grep -oE '^[0-9]{4}-[0-9]{2}-[0-9]{2}' || echo "")
        echo "| ${fdate:-?} | [$title]($file) | $type |" >> jira/index.md
    done
}

# ============================================================
work_save() {
    local MSG="${1:-중간 저장}"

    local TODAY_LOG=$(find "$LOG_DIR" -name "$DATE-*.md" -type f 2>/dev/null | sort -r | head -1)
    if [ -n "$TODAY_LOG" ] && [ -f "$TODAY_LOG" ]; then
        printf '\n### 저장포인트 (%s) — %s\n' "$(date '+%H:%M')" "$MSG" >> "$TODAY_LOG"
        echo -e "${GREEN}✅ 저장포인트 추가: $TODAY_LOG${NC}"
    else
        echo -e "${YELLOW}오늘 작업 로그 없음. ./work start \"작업명\" 먼저 실행하세요${NC}"
    fi

    update_status "$MSG"
    update_index
    echo -e "${GREEN}✅ 저장: $MSG${NC}"
}

# ============================================================
work_done() {
    local MSG="${1:-작업 완료}"

    local TODAY_LOG=$(find "$LOG_DIR" -name "$DATE-*.md" -type f 2>/dev/null | sort -r | head -1)
    if [ -n "$TODAY_LOG" ] && [ -f "$TODAY_LOG" ]; then
        local DIFF=$(git diff --stat 2>/dev/null)
        if [ -n "$DIFF" ]; then
            printf '\n## 변경 파일 (자동)\n```\n%s\n```\n' "$DIFF" >> "$TODAY_LOG"
        fi
    fi

    update_status "$MSG"
    update_index
    update_jira_index

    if [ -z "$(git status --porcelain)" ]; then
        echo -e "${YELLOW}변경 사항 없음${NC}"
    else
        git add .
        git commit -m "$MSG" > /dev/null 2>&1
        echo -e "${GREEN}✅ commit: $MSG${NC}"

        if git remote | grep -q 'origin'; then
            local BRANCH=$(git branch --show-current)
            git push origin "$BRANCH" 2>/dev/null \
                && echo -e "${GREEN}✅ push 완료${NC}" \
                || echo -e "${YELLOW}push 실패 (수동: git push)${NC}"
        fi
    fi

    local OPEN_COUNT=$(find jira/open -name "*.md" -type f 2>/dev/null | wc -l | tr -d ' ')
    if [ "$OPEN_COUNT" -gt 0 ]; then
        echo -e "\n${YELLOW}Jira open ${OPEN_COUNT}개 → ./work jira list${NC}"
    fi
}

# ============================================================
work_status() {
    if [ -f "context/current_status.md" ]; then
        grep -A 1 "## 마지막 완료" context/current_status.md 2>/dev/null | tail -1
    fi
    echo ""
    local TODAY=$(find "$LOG_DIR" -name "$DATE-*.md" -type f 2>/dev/null)
    if [ -n "$TODAY" ]; then
        echo -e "  ${GREEN}오늘:${NC}"
        for f in $TODAY; do echo "    $(basename "$f" .md)"; done
    else
        echo -e "  ${DIM}오늘 작업 없음${NC}"
    fi
    echo -e "  history: $(find history -name "*.md" -not -name "index.md" -type f 2>/dev/null | wc -l | tr -d ' ')개"

    local OPEN=$(find jira/open -name "*.md" -type f 2>/dev/null | wc -l | tr -d ' ')
    [ "$OPEN" -gt 0 ] && echo -e "  ${YELLOW}Jira open: ${OPEN}개${NC}"
    echo ""
}

# ============================================================
work_jira_create() {
    local TITLE="${1:-태스크}"
    local TYPE="${2:-improvement}"
    local PRIORITY="${3:-medium}"

    mkdir -p jira/open

    local SLUG=$(echo "$TITLE" | tr ' ' '-' | tr '[:upper:]' '[:lower:]')
    local JIRA_FILE="jira/open/$DATE-$SLUG.md"

    if [ -f "$JIRA_FILE" ]; then
        echo -e "${YELLOW}이미 존재: $JIRA_FILE${NC}"
        return 0
    fi

    local SOURCE_LOG=$(find history -name "*.md" -not -name "index.md" -type f 2>/dev/null | sort -r | head -1)

    cat > "$JIRA_FILE" << EOF
---
date: $DATE
title: $TITLE
type: $TYPE
priority: $PRIORITY
source: ${SOURCE_LOG:-""}
status: open
---

# $TITLE

## 배경
(어떤 작업 중 발견/도출되었는지)

## 요구사항
-

## 완료 기준
-

## 참고
-
EOF

    update_jira_index
    echo -e "${GREEN}✅ $JIRA_FILE${NC}"
}

# ============================================================
work_jira_close() {
    local FILE="$1"
    if [ -z "$FILE" ]; then
        echo -e "${RED}파일명을 지정하세요${NC}"; return 1
    fi

    [ ! -f "$FILE" ] && [ -f "jira/open/$FILE" ] && FILE="jira/open/$FILE"

    if [ ! -f "$FILE" ]; then
        echo -e "${RED}파일 없음: $FILE${NC}"; return 1
    fi

    mkdir -p jira/done
    local BASENAME=$(basename "$FILE")
    mv "$FILE" "jira/done/$BASENAME"

    sed -i.bak 's/^status: open/status: done/' "jira/done/$BASENAME" 2>/dev/null || true
    rm -f "jira/done/$BASENAME.bak"

    update_jira_index
    echo -e "${GREEN}✅ 완료: jira/done/$BASENAME${NC}"
}

# ============================================================
work_jira_list() {
    local OPEN_COUNT=$(find jira/open -name "*.md" -type f 2>/dev/null | wc -l | tr -d ' ')
    local DONE_COUNT=$(find jira/done -name "*.md" -type f 2>/dev/null | wc -l | tr -d ' ')

    echo -e "\n${BLUE}Jira 태스크${NC}"
    echo -e "  ${GREEN}open ($OPEN_COUNT)${NC}"

    find jira/open -name "*.md" -type f 2>/dev/null | sort | while read file; do
        local fname=$(basename "$file" .md)
        local title=$(grep "^title:" "$file" 2>/dev/null | sed 's/^title: //' || echo "$fname")
        local priority=$(grep "^priority:" "$file" 2>/dev/null | sed 's/^priority: //' || echo "medium")
        local type=$(grep "^type:" "$file" 2>/dev/null | sed 's/^type: //' || echo "-")
        echo -e "    ${DIM}[$priority]${NC} $title  ${DIM}($type)${NC}"
    done

    echo -e "  ${DIM}done ($DONE_COUNT)${NC}"
    echo ""
}

# ============================================================
case "${1:-help}" in
    start)  work_start "${2:-work}" ;;
    save)   work_save "${2:-중간 저장}" ;;
    done)   work_done "${2:-작업 완료}" ;;
    status) work_status ;;
    jira)
        case "${2:-list}" in
            new|create) work_jira_create "${3:-태스크}" "${4:-improvement}" "${5:-medium}" ;;
            done)       work_jira_close "$3" ;;
            list|*)     work_jira_list ;;
        esac
        ;;
    help|--help|-h) show_help ;;
    *) echo -e "${RED}알 수 없는 명령어: $1${NC}"; show_help; exit 1 ;;
esac
